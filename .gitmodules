[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	branch = HEAD
[submodule "evacpath"]
	path = evacpath
	url = https://github.com/el-cordero/evacpath
[submodule "pointcoral"]
	path = pointcoral
	url = https://github.com/el-cordero/pointcoral
[submodule "potentiomap"]
	path = potentiomap
	url = https://github.com/el-cordero/potentiomap
